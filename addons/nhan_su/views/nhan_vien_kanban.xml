<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_nhan_vien_kanban" model="ir.ui.view">
            <field name="name">nhan_vien.kanban</field>
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <kanban class="nhan_su_kanban">
                    <field name="id"/>
                    <field name="ho_ten"/>
                    <field name="hinh_anh"/>
                    <field name="chuc_vu_id"/>
                    <field name="phong_ban_id"/>
                    <field name="email"/>
                    <field name="so_dien_thoai"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="ho_ten"/>
                                        </strong>
                                        <span class="o_kanban_record_subtitle text-muted">
                                            <field name="chuc_vu_id"/>
                                        </span>
                                    </div>
                                    <div class="o_kanban_image">
                                        <t t-if="record.hinh_anh.raw_value">
                                            <img t-att-src="kanban_image('nhan_vien', 'hinh_anh', record.id.raw_value)" class="o_kanban_image" alt="Avatar"/>
                                        </t>
                                        <t t-else="">
                                            <img src="/web/static/src/img/placeholder.png" class="o_kanban_image" alt="Avatar"/>
                                        </t>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div t-if="record.phong_ban_id.value">
                                        <i class="fa fa-building-o text-muted"/> <field name="phong_ban_id"/>
                                    </div>
                                    <div t-if="record.email.value">
                                        <i class="fa fa-envelope text-muted"/> <field name="email"/>
                                    </div>
                                    <div t-if="record.so_dien_thoai.value">
                                        <i class="fa fa-phone text-muted"/> <field name="so_dien_thoai"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>
    </data>
</odoo>
