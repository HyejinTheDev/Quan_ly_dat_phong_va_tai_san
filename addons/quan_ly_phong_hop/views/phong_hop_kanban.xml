<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_phong_hop_kanban" model="ir.ui.view">
            <field name="name">phong_hop.kanban</field>
            <field name="model">phong_hop</field>
            <field name="arch" type="xml">
                <kanban class="phong_hop_kanban">
                    <field name="id"/>
                    <field name="ten_phong"/>
                    <field name="hinh_anh"/>
                    <field name="suc_chua"/>
                    <field name="vi_tri"/>
                    <field name="trang_thai"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title" style="font-size: 16px;">
                                            <i class="fa fa-building"/> <field name="ten_phong"/>
                                        </strong>
                                    </div>
                                    <div class="o_kanban_image">
                                        <t t-if="record.hinh_anh.raw_value">
                                            <img t-att-src="kanban_image('phong_hop', 'hinh_anh', record.id.raw_value)" class="o_kanban_image" alt="Ảnh"/>
                                        </t>
                                        <t t-else="">
                                            <img src="/web/static/src/img/placeholder.png" class="o_kanban_image" alt="Ảnh"/>
                                        </t>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div>
                                        <i class="fa fa-users text-muted"/> Sức chứa: <strong><field name="suc_chua"/></strong> người
                                    </div>
                                    <div t-if="record.vi_tri.value">
                                        <i class="fa fa-map-marker text-muted"/> <field name="vi_tri"/>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="trang_thai" widget="label_selection" options="{'classes': {'san_sang': 'success', 'dang_su_dung': 'warning', 'bao_tri': 'danger'}}"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>
    </data>
</odoo>
