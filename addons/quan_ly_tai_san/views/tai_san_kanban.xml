<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_tai_san_kanban" model="ir.ui.view">
            <field name="name">tai_san.kanban</field>
            <field name="model">tai_san</field>
            <field name="arch" type="xml">
                <kanban class="tai_san_kanban">
                    <field name="id"/>
                    <field name="ten_tai_san"/>
                    <field name="hinh_anh"/>
                    <field name="danh_muc_id"/>
                    <field name="trang_thai"/>
                    <field name="gia_tri"/>
                    <field name="vi_tri"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="ten_tai_san"/>
                                        </strong>
                                        <span class="o_kanban_record_subtitle text-muted">
                                            <field name="danh_muc_id"/>
                                        </span>
                                    </div>
                                    <div class="o_kanban_image">
                                        <t t-if="record.hinh_anh.raw_value">
                                            <img t-att-src="kanban_image('tai_san', 'hinh_anh', record.id.raw_value)" class="o_kanban_image" alt="Ảnh"/>
                                        </t>
                                        <t t-else="">
                                            <img src="/web/static/src/img/placeholder.png" class="o_kanban_image" alt="Ảnh"/>
                                        </t>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div>
                                        <i class="fa fa-map-marker text-muted"/> <field name="vi_tri"/>
                                    </div>
                                    <div>
                                        <i class="fa fa-money text-muted"/>
                                        <field name="gia_tri" widget="monetary"/> VNĐ
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="trang_thai" widget="label_selection" options="{'classes': {'san_sang': 'success', 'dang_muon': 'info', 'bao_tri': 'warning', 'hong': 'danger', 'mat': 'danger'}}"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>
    </data>
</odoo>
